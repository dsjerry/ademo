<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>所有鼠标效果示例</title>
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
    background: #0f0f1a;
    color: #e0e0e0;
    min-height: 100vh;
    overflow-x: hidden;
  }
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #1a1a2e; }
  ::-webkit-scrollbar-thumb { background: #4a4a6a; border-radius: 3px; }

  header { text-align: center; padding: 60px 20px 40px; }
  header h1 {
    font-size: 2.8rem; font-weight: 700;
    background: linear-gradient(135deg, #ff6b9d, #c084fc, #60a5fa);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
  }
  header p { margin-top: 12px; color: #888; font-size: 1rem; letter-spacing: 1px; }

  .container { max-width: 1280px; margin: 0 auto; padding: 0 20px 80px; }
  .section-title {
    font-size: 1.4rem; margin: 48px 0 24px;
    padding-left: 16px; border-left: 4px solid #ff6b9d;
    color: #ccc; font-weight: 600;
  }

  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }

  .card {
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 16px;
    padding: 24px 18px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform .3s, box-shadow .3s, border-color .3s;
  }
  .card .icon { font-size: 1.8rem; margin-bottom: 8px; }
  .card h3 { font-size: .95rem; font-weight: 600; color: #ddd; margin-bottom: 4px; }
  .card p { font-size: .75rem; color: #777; line-height: 1.5; }

  /* 代码片段 */
  .code-snip {
    margin-top: 12px;
    padding: 8px 10px;
    background: rgba(0,0,0,.35);
    border-radius: 8px;
    border: 1px solid rgba(255,255,255,.04);
    font-family: 'SF Mono', 'Fira Code', 'JetBrains Mono', monospace;
    font-size: .62rem;
    color: #a78bfa;
    text-align: left;
    white-space: pre;
    overflow-x: auto;
    line-height: 1.6;
    user-select: text;
  }
  .code-snip .cm { color: #555; } /* comment */
  .code-snip .kw { color: #60a5fa; } /* keyword / selector */
  .code-snip .fn { color: #fbbf24; } /* function */
  .code-snip .str { color: #34d399; } /* string */
  .code-snip .num { color: #fb923c; } /* number */
  .code-snip .pun { color: #888; } /* punctuation */

  .tag {
    display: inline-block;
    font-size: .6rem; padding: 2px 7px;
    border-radius: 4px;
    background: rgba(255,255,255,.06);
    color: #555;
    margin-top: 6px;
    font-family: monospace;
  }

  /* ---- 光标展示卡 ---- */
  .cursor-card { cursor: default; min-height: 120px; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .cursor-card .cursor-name { font-size: 1rem; font-weight: 600; color: #ccc; margin-bottom: 4px; }
  .cursor-card .cursor-value {
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: .72rem; color: #ff6b9d;
    background: rgba(255,107,157,.08);
    padding: 2px 10px; border-radius: 6px;
  }

  /* ---- Hover ---- */
  .card-hover-lift:hover { transform: translateY(-8px); box-shadow: 0 12px 40px rgba(255,107,157,.15); border-color: rgba(255,107,157,.3); }
  .card-hover-scale:hover { transform: scale(1.06); box-shadow: 0 8px 30px rgba(192,132,252,.2); border-color: rgba(192,132,252,.3); }
  .card-hover-rotate:hover { transform: perspective(600px) rotateY(6deg) rotateX(-4deg); box-shadow: 0 20px 40px rgba(96,165,250,.15); border-color: rgba(96,165,250,.3); }
  .card-hover-glare { perspective: 600px; }
  .card-hover-glare .glare-bg {
    position: absolute; inset: 0; border-radius: 16px;
    background: radial-gradient(circle at 50% 50%, rgba(255,255,255,.12), transparent 60%);
    opacity: 0; transition: opacity .3s;
    pointer-events: none;
  }
  .card-hover-border-glow:hover { box-shadow: 0 0 25px rgba(251,146,60,.25); border-color: rgba(251,146,60,.5); }
  .card-hover-flip { perspective: 800px; }
  .card-hover-flip-inner { transition: transform .5s ease; transform-style: preserve-3d; }
  .card-hover-flip:hover .card-hover-flip-inner { transform: rotateY(180deg); }
  .card-hover-flip-back { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; backface-visibility: hidden; transform: rotateY(180deg); background: linear-gradient(145deg, #1e1e3a, #2a1a3e); border-radius: 16px; padding: 20px; }
  .card-hover-squash:hover { transform: scaleX(1.08) scaleY(.92); }

  /* ---- Click ---- */
  .card-ripple { cursor: pointer; user-select: none; }
  .ripple-effect { position: absolute; border-radius: 50%; background: rgba(255,255,255,.25); transform: scale(0); animation: rippleAnim .6s ease-out; pointer-events: none; }
  @keyframes rippleAnim { to { transform: scale(4); opacity: 0; } }
  .card-click-burst { cursor: pointer; user-select: none; }

  /* ---- Trail ---- */
  .trail-wrap {
    position: relative; height: 200px; border-radius: 16px; overflow: hidden;
    cursor: default; grid-column: 1 / -1;
  }
  .trail-wrap canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .trail-wrap .hint {
    position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
    color: rgba(255,255,255,.08); font-size: .8rem; letter-spacing: 2px; pointer-events: none;
  }
  .full-code { grid-column: 1 / -1; }

  /* ---- Magnet ---- */
  .card-magnet { cursor: pointer; }

  /* ---- Parallax ---- */
  .parallax-container {
    display: flex; justify-content: center; align-items: center;
    height: 240px; border-radius: 16px;
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,.06);
    position: relative; overflow: hidden;
    grid-column: 1 / -1;
  }
  .parallax-layer { position: absolute; pointer-events: none; transition: transform .08s ease-out; }
  .parallax-layer.l1 { width: 80px; height: 80px; background: rgba(255,107,157,.15); border-radius: 50%; top: 20%; left: 20%; }
  .parallax-layer.l2 { width: 50px; height: 50px; background: rgba(192,132,252,.12); border-radius: 8px; top: 60%; left: 50%; transform: rotate(45deg); }
  .parallax-layer.l3 { width: 120px; height: 120px; border: 2px solid rgba(96,165,250,.08); border-radius: 50%; top: 30%; left: 65%; }
  .parallax-layer.l4 { width: 30px; height: 30px; background: rgba(251,146,60,.1); border-radius: 50%; top: 70%; left: 25%; }
  .parallax-layer.l5 { width: 60px; height: 60px; border: 2px solid rgba(52,211,153,.08); border-radius: 50%; top: 15%; left: 45%; }
  .parallax-center-text { position: relative; z-index: 2; font-size: 1.1rem; color: rgba(255,255,255,.12); letter-spacing: 3px; pointer-events: none; }

  /* ---- Direction ---- */
  .card-direction { cursor: pointer; overflow: hidden; }
  .card-direction .dir-overlay { position: absolute; inset: 0; background: radial-gradient(circle at center, rgba(255,107,157,.2), transparent 60%); opacity: 0; transition: opacity .3s; pointer-events: none; }
  .card-direction .dir-label { position: absolute; top: 10px; right: 14px; font-size: .65rem; color: rgba(255,255,255,.15); text-transform: uppercase; letter-spacing: 1px; pointer-events: none; }

  /* ---- Drag ---- */
  .drag-area {
    position: relative; height: 240px; border-radius: 16px;
    border: 2px dashed rgba(255,255,255,.08);
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .drag-area .hint { color: rgba(255,255,255,.06); font-size: .75rem; pointer-events: none; }
  .drag-item {
    position: absolute; width: 80px; height: 80px;
    background: linear-gradient(135deg, #ff6b9d, #c084fc);
    border-radius: 16px; display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 1.2rem;
    cursor: grab; user-select: none;
    box-shadow: 0 8px 25px rgba(255,107,157,.25);
    transition: box-shadow .3s, transform .2s; z-index: 2;
  }
  .drag-item:active { cursor: grabbing; transform: scale(1.08); box-shadow: 0 12px 35px rgba(255,107,157,.35); }

  .drop-zone {
    position: relative; height: 140px; border-radius: 16px;
    border: 2px dashed rgba(239,68,68,.12);
    grid-column: 1 / -1;
    display: flex; align-items: center; justify-content: center; gap: 24px;
    padding: 20px; background: rgba(239,68,68,.02); user-select: none;
  }
  .drop-item-a { padding: 18px 32px; border-radius: 12px; background: linear-gradient(135deg, #ff6b9d, #c084fc); color: #fff; font-size: .9rem; cursor: copy; user-select: none; box-shadow: 0 6px 20px rgba(255,107,157,.2); }
  .drop-item-b { padding: 18px 32px; border-radius: 12px; background: #2a2a4a; color: rgba(255,255,255,.15); font-size: .85rem; cursor: no-drop; user-select: none; border: 1px solid rgba(239,68,68,.12); }
  .drop-zone-label { position: absolute; top: 10px; left: 16px; font-size: .65rem; color: rgba(255,255,255,.08); letter-spacing: 1px; }

  /* ---- Scroll ---- */
  .scroll-control {
    grid-column: 1 / -1;
    display: flex; align-items: center; gap: 20px;
    padding: 28px; border-radius: 16px;
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,.06);
  }
  .scroll-progress { flex: 1; height: 6px; border-radius: 3px; background: #2a2a4a; overflow: hidden; }
  .scroll-progress-bar { height: 100%; width: 0; border-radius: 3px; background: linear-gradient(90deg, #ff6b9d, #c084fc, #60a5fa); transition: width .05s linear; }
  .scroll-value { font-size: 1.1rem; font-weight: 700; color: #ff6b9d; min-width: 44px; text-align: center; }
  .scroll-hint { color: rgba(255,255,255,.12); font-size: .7rem; }

  /* ---- Particle Click ---- */
  .particle-click-area {
    grid-column: 1 / -1; height: 200px; border-radius: 16px;
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,.06);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; position: relative; overflow: hidden; user-select: none;
  }
  .particle-click-area .hint { color: rgba(255,255,255,.08); font-size: .78rem; letter-spacing: 2px; pointer-events: none; }
  .click-particle { position: absolute; width: 6px; height: 6px; border-radius: 50%; pointer-events: none; }

  /* ---- Text Hover ---- */
  .text-hover-area {
    grid-column: 1 / -1; padding: 40px 28px; border-radius: 16px;
    background: linear-gradient(145deg, #1a1a2e, #16213e);
    border: 1px solid rgba(255,255,255,.06);
    text-align: center;
  }
  .text-hover-area .word {
    display: inline-block; font-size: 2rem; font-weight: 700;
    margin: 0 8px; padding: 4px 6px; cursor: pointer;
    transition: color .3s, transform .3s; position: relative;
  }
  .text-hover-area .word::after {
    content: attr(data-char); position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    color: #ff6b9d;
    clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0 100%);
    transition: clip-path .35s ease;
  }
  .text-hover-area .word:hover::after { clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%); }
  .text-hover-area .word:hover { transform: scale(1.08); }
</style>
</head>
