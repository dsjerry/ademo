<script>
// ============================================================
//  Glare
// ============================================================
const glareCard = document.getElementById('glare-card');
const glareBg = document.getElementById('glare-bg');
glareCard.addEventListener('mousemove', e => {
  const rect = glareCard.getBoundingClientRect();
  const x = ((e.clientX - rect.left) / rect.width) * 100;
  const y = ((e.clientY - rect.top) / rect.height) * 100;
  glareBg.style.background = `radial-gradient(circle at ${x}% ${y}%, rgba(255,255,255,.15), transparent 60%)`;
  glareBg.style.opacity = 1;
});
glareCard.addEventListener('mouseleave', () => { glareBg.style.opacity = 0; });

// ============================================================
//  Ripple
// ============================================================
document.getElementById('ripple-card').addEventListener('click', function(e) {
  const rect = this.getBoundingClientRect();
  const size = Math.max(rect.width, rect.height);
  const x = e.clientX - rect.left - size / 2;
  const y = e.clientY - rect.top - size / 2;
  const ripple = document.createElement('div');
  ripple.className = 'ripple-effect';
  ripple.style.width = ripple.style.height = size + 'px';
  ripple.style.left = x + 'px';
  ripple.style.top = y + 'px';
  this.appendChild(ripple);
  ripple.addEventListener('animationend', () => ripple.remove());
});

// ============================================================
//  Burst
// ============================================================
document.getElementById('burst-card').addEventListener('click', function(e) {
  const rect = this.getBoundingClientRect();
  const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
  const colors = ['#ff6b9d','#c084fc','#60a5fa','#fb923c','#34d399','#fbbf24'];
  for (let i = 0; i < 12; i++) {
    const p = document.createElement('div');
    p.style.cssText = `position:absolute;width:6px;height:6px;border-radius:50%;background:${colors[i%colors.length]};pointer-events:none;left:${cx}px;top:${cy}px;`;
    this.appendChild(p);
    const angle = (Math.PI * 2 * i) / 12;
    const dist = 40 + Math.random() * 30;
    p.animate([
      { transform: 'translate(0,0) scale(1)', opacity: 1 },
      { transform: `translate(${Math.cos(angle)*dist}px,${Math.sin(angle)*dist}px) scale(0)`, opacity: 0 }
    ], { duration: 600, easing: 'ease-out' }).onfinish = () => p.remove();
  }
});

// ============================================================
//  Counter & Color & DblClick & LongPress
// ============================================================
let clickCount = 0;
document.getElementById('click-counter-card').addEventListener('click', function() {
  document.getElementById('click-count').textContent = ++clickCount;
});
document.getElementById('click-color-card').addEventListener('click', function() {
  const hue = Math.floor(Math.random() * 360);
  this.style.background = `linear-gradient(145deg, hsl(${hue},50%,10%), hsl(${hue+30},50%,15%))`;
});
document.getElementById('doubleclick-card').addEventListener('dblclick', function() {
  const msg = document.createElement('div');
  msg.textContent = '🎯 双击触发！';
  msg.style.cssText = 'margin-top:10px;color:#ff6b9d;font-size:.85rem;animation:fadeUp .6s forwards;';
  this.appendChild(msg);
  setTimeout(() => msg.remove(), 800);
});
const lpCard = document.getElementById('longpress-card');
const lpFill = document.getElementById('longpress-fill');
let longPressTimer = 0;
lpCard.addEventListener('mousedown', () => {
  let pct = 0;
  longPressTimer = setInterval(() => {
    pct += 10;
    lpFill.style.width = pct + '%';
    if (pct >= 100) {
      clearInterval(longPressTimer);
      const n = document.createElement('div');
      n.textContent = '🔥 长按触发！';
      n.style.cssText = 'margin-top:8px;color:#ff6b9d;font-size:.8rem;';
      lpCard.appendChild(n);
      setTimeout(() => { n.remove(); lpFill.style.width = '0'; }, 1500);
    }
  }, 100);
});
lpCard.addEventListener('mouseup', () => { clearInterval(longPressTimer); lpFill.style.width = '0'; });
lpCard.addEventListener('mouseleave', () => { clearInterval(longPressTimer); lpFill.style.width = '0'; });

// ============================================================
//  Trail
// ============================================================
const canvas = document.getElementById('trail-canvas');
const ctx = canvas.getContext('2d');
const wrap = document.getElementById('trail-wrap');
function resizeCanvas() { canvas.width = wrap.offsetWidth; canvas.height = wrap.offsetHeight; }
resizeCanvas();
window.addEventListener('resize', resizeCanvas);
const trailPts = [];
const trailColors = ['#ff6b9d','#c084fc','#60a5fa','#fb923c','#34d399','#fbbf24'];
wrap.addEventListener('mousemove', e => {
  const rect = wrap.getBoundingClientRect();
  const x = e.clientX - rect.left, y = e.clientY - rect.top;
  for (let i = 0; i < 3; i++) {
    trailPts.push({ x, y, vx: (Math.random()-0.5)*2, vy: (Math.random()-0.5)*2-1, size: 2+Math.random()*4, color: trailColors[Math.floor(Math.random()*trailColors.length)], life: 1 });
  }
});
function animateTrail() {
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  for (let i = trailPts.length - 1; i >= 0; i--) {
    const p = trailPts[i]; p.x += p.vx; p.y += p.vy; p.vy += 0.02; p.life -= 0.015;
    if (p.life <= 0) { trailPts.splice(i, 1); continue; }
    ctx.globalAlpha = p.life; ctx.fillStyle = p.color;
    ctx.beginPath(); ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2); ctx.fill();
  }
  ctx.globalAlpha = 1;
  requestAnimationFrame(animateTrail);
}
animateTrail();

// ============================================================
//  Magnet
// ============================================================
document.querySelectorAll('.card-magnet').forEach(card => {
  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const dx = e.clientX - rect.left - rect.width / 2;
    const dy = e.clientY - rect.top - rect.height / 2;
    const dist = Math.sqrt(dx * dx + dy * dy);
    const strength = Math.max(0, 1 - dist / 120);
    const mx = dx * strength * 0.2;
    const my = dy * strength * 0.2;
    if (card.id === 'magnet-card') card.style.transform = `translate(${mx}px,${my}px)`;
    else if (card.id === 'magnet-card2') card.style.transform = `translate(${mx}px,${my}px) rotate(${mx*0.3}deg)`;
    else if (card.id === 'magnet-card3') card.style.transform = `translate(${mx}px,${my}px) scale(${1+strength*0.04})`;
  });
  card.addEventListener('mouseleave', () => { card.style.transform = ''; });
});

// ============================================================
//  Parallax
// ============================================================
const parallaxContainer = document.getElementById('parallax-container');
const parallaxLayers = parallaxContainer.querySelectorAll('.parallax-layer');
parallaxContainer.addEventListener('mousemove', e => {
  const rect = parallaxContainer.getBoundingClientRect();
  const cx = rect.left + rect.width / 2, cy = rect.top + rect.height / 2;
  const dx = e.clientX - cx, dy = e.clientY - cy;
  parallaxLayers.forEach(layer => { layer.style.transform = `translate(${dx*parseFloat(layer.dataset.speed)}px,${dy*parseFloat(layer.dataset.speed)}px)`; });
});
parallaxContainer.addEventListener('mouseleave', () => { parallaxLayers.forEach(layer => { layer.style.transform = ''; }); });

// ============================================================
//  Direction
// ============================================================
function setupDirCard(cardId, overlayId, labelId) {
  const card = document.getElementById(cardId), overlay = document.getElementById(overlayId), label = document.getElementById(labelId);
  const dirMap = ['⬇️ bottom','⬅️ left','⬆️ top','➡️ right'];
  card.addEventListener('mouseenter', e => {
    const rect = card.getBoundingClientRect();
    const w = rect.width, h = rect.height;
    const x = e.clientX - rect.left, y = e.clientY - rect.top;
    const vals = [y, w-x, h-y, x];
    const minIdx = vals.indexOf(Math.min(...vals));
    const dirs = ['top','right','bottom','left'];
    const start = { top:'inset(100% 0 0 0)', right:'inset(0 0 0 100%)', bottom:'inset(0 0 100% 0)', left:'inset(0 100% 0 0)' };
    overlay.style.clipPath = start[dirs[minIdx]];
    overlay.style.opacity = 1;
    requestAnimationFrame(() => { overlay.style.clipPath = 'inset(0)'; });
    label.textContent = dirMap[minIdx];
  });
  card.addEventListener('mouseleave', e => {
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left, y = e.clientY - rect.top;
    const vals = [y, rect.width-x, rect.height-y, x];
    const minIdx = vals.indexOf(Math.min(...vals));
    const dirs = ['top','right','bottom','left'];
    const end = { top:'inset(100% 0 0 0)', right:'inset(0 0 0 100%)', bottom:'inset(0 0 100% 0)', left:'inset(0 100% 0 0)' };
    overlay.style.clipPath = end[dirs[minIdx]];
    setTimeout(() => { overlay.style.opacity = 0; }, 400);
  });
}
setupDirCard('dir-card','dir-overlay','dir-label');
setupDirCard('dir-card2','dir-overlay2','dir-label2');

// ============================================================
//  Drag
// ============================================================
const dragItem = document.getElementById('drag-item');
const dragArea = document.getElementById('drag-area');
let isDragging = false, dragOffX = 0, dragOffY = 0;
dragItem.addEventListener('mousedown', e => {
  isDragging = true;
  const rect = dragItem.getBoundingClientRect();
  dragOffX = e.clientX - rect.left; dragOffY = e.clientY - rect.top;
  dragItem.style.zIndex = 10;
});
document.addEventListener('mousemove', e => {
  if (!isDragging) return;
  const areaRect = dragArea.getBoundingClientRect();
  let x = e.clientX - areaRect.left - dragOffX;
  let y = e.clientY - areaRect.top - dragOffY;
  x = Math.max(0, Math.min(x, areaRect.width - 80));
  y = Math.max(0, Math.min(y, areaRect.height - 80));
  dragItem.style.left = x + 'px'; dragItem.style.top = y + 'px';
});
document.addEventListener('mouseup', () => { isDragging = false; dragItem.style.zIndex = 2; });
dragItem.style.left = '20px'; dragItem.style.top = '20px';

// ============================================================
//  Scroll
// ============================================================
const scrollCtrl = document.getElementById('scroll-control');
const scrollBar = document.getElementById('scroll-bar');
const scrollVal = document.getElementById('scroll-value');
let scrollPct = 0;
scrollCtrl.addEventListener('wheel', e => {
  e.preventDefault();
  scrollPct = Math.max(0, Math.min(100, scrollPct + (e.deltaY > 0 ? 5 : -5)));
  scrollBar.style.width = scrollPct + '%';
  scrollVal.textContent = Math.round(scrollPct) + '%';
}, { passive: false });

// ============================================================
//  Click Particles
// ============================================================
const pArea = document.getElementById('particle-area');
const pColors = ['#ff6b9d','#c084fc','#60a5fa','#fb923c','#34d399','#fbbf24','#f472b6','#a78bfa'];
pArea.addEventListener('click', e => {
  const rect = pArea.getBoundingClientRect();
  const cx = e.clientX - rect.left, cy = e.clientY - rect.top;
  for (let i = 0; i < 30; i++) {
    const p = document.createElement('div');
    p.className = 'click-particle';
    const color = pColors[Math.floor(Math.random()*pColors.length)];
    const size = 3 + Math.random() * 5;
    const angle = Math.random() * Math.PI * 2;
    const speed = 60 + Math.random() * 100;
    p.style.cssText = `left:${cx}px;top:${cy}px;width:${size}px;height:${size}px;background:${color};`;
    pArea.appendChild(p);
    p.animate([
      { transform: 'translate(0,0) scale(1)', opacity: 1 },
      { transform: `translate(${Math.cos(angle)*speed}px,${Math.sin(angle)*speed}px) scale(0)`, opacity: 0 }
    ], { duration: 700+Math.random()*400, easing: 'cubic-bezier(0,.8,.5,1)' }).onfinish = () => p.remove();
  }
});

// ============================================================
//  fadeUp
// ============================================================
const ss = document.createElement('style');
ss.textContent = `@keyframes fadeUp { from{opacity:1;transform:translateY(0)} to{opacity:0;transform:translateY(-20px)} }`;
document.head.appendChild(ss);
</script>
