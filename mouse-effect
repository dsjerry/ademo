      <div class="icon">🔢</div><h3>计数</h3><p>点击 <span id="click-count" style="color:#ff6b9d;font-weight:700;">0</span></p>
      <div class="code-snip"><span class="fn">let</span> count = 0;
<span class="fn">el</span>.addEventListener(<span class="str">'click'</span>, <span class="pun">()</span> =&gt; <span class="pun">{</span>
