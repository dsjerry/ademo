      <div class="code-snip"><span class="kw">el</span>.addEventListener(<span class="str">'click'</span>, <span class="pun">()</span> =&gt; <span class="pun">{</span>
  <span class="fn">const</span> h = Math.random() * 360;
  <span class="kw">el</span>.style.background =
